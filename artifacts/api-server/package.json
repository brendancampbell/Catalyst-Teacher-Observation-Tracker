{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "seed": "node --enable-source-maps ./dist/seed.mjs",
    "seed-dev": "node --enable-source-maps ./dist/seed-dev.mjs",
    "build:all": "node ./build.mjs && node --enable-source-maps ./dist/migrate.mjs && pnpm --filter @workspace/db tsx src/migrate-rubric-domain-rubric-set-id.ts && pnpm --filter @workspace/db run push-force && node --enable-source-maps ./dist/seed.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc --build ../../lib/db ../../lib/api-zod ../../lib/integrations-anthropic-ai && tsc -p tsconfig.json --noEmit",
    "test:school-lookup": "tsx src/test-bulk-import-school-lookup.ts",
    "test:admin-schools-validation": "tsx src/test-admin-schools-validation.ts",
    "test:bulk-people-school-validation": "tsx src/test-bulk-people-school-validation.ts",
    "test:email-injection": "tsx src/test-email-html-injection.ts",
    "test:return-to-redirect": "tsx src/test-return-to-redirect.ts",
    "test:coach-cross-school-auth": "tsx src/test-coach-cross-school-auth.ts",
    "test:observation-score-validation": "tsx src/test-observation-score-validation.ts",
    "test:email-school-scope-auth": "tsx src/test-email-school-scope-auth.ts",
    "test:impersonation-endpoints": "tsx src/test-impersonation-endpoints.ts",
    "test:impersonation-middleware": "tsx --test src/test-impersonation-middleware.ts",
    "test:coach-admin-block": "tsx src/test-coach-admin-block.ts",
    "test:session-expiry": "tsx src/test-session-expiry.ts",
    "test:rubric-category-domain-validation": "tsx src/test-rubric-category-domain-validation.ts",
    "test:action-steps-e2e": "tsx --test src/test-action-steps-e2e.ts",
    "seed:teachers": "tsx src/seed-teachers.ts",
    "test:demo-teachers": "tsx src/test-demo-teachers-visibility.ts",
    "test:patch-people-role-escalation": "tsx src/test-patch-people-role-escalation.ts",
    "test:bulk-people-role-escalation": "tsx --test src/test-bulk-people-role-escalation.ts",
    "test:network-school-isolation": "tsx --test src/test-network-school-isolation.ts",
    "test:ai-qualitative-school-scope": "tsx --test src/test-ai-qualitative-school-scope.ts",
    "test:ai-teacher-transfer-scope": "tsx --test src/test-ai-teacher-transfer-scope.ts",
    "test:overdue-action-steps": "tsx --test src/test-overdue-action-steps.ts",
    "test:feedback-tracker-homeoffice-exclusion": "tsx src/test-feedback-tracker-homeoffice-exclusion.ts",
    "test:bulk-import-cross-school": "tsx --test src/test-bulk-import-cross-school.ts",
    "test:snapshot-freeze": "tsx --test src/test-snapshot-freeze.ts",
    "test:rate-limit-observations": "tsx src/test-observation-rate-limit.ts",
    "test:ai-quota-grant-bypass": "tsx --test src/test-ai-quota-grant-bypass.ts"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "4.0.0",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "catalog:",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/sanitize-html": "^2.16.1",
    "esbuild": "^0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
