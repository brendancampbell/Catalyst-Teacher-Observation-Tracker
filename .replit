[[workflows.workflow]]
name = "test:admin-schools-validation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test:admin-schools-validation"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dashboard-header-pills"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-dashboard && CHROMIUM_PATH=$(which chromium) pnpm test:e2e e2e/app-header-pills.spec.ts"

[[workflows.workflow]]
name = "mobile-observation-no-overflow"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-mobile && PW_BASE_URL=http://127.0.0.1:25869/catalyst-mobile/ CHROMIUM_PATH=$(which chromium) pnpm playwright test --config playwright.config.ts"

[workflows.workflow.metadata]
isValidation = true

