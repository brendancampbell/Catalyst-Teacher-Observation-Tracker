args = "dashboard-rubric-domain-slug-validation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:category-deletion-guard"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:action-step-upsert"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:people-school-orphaned"

[[workflows.workflow.tasks]]
