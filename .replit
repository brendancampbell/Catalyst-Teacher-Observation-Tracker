modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:admin-schools-validation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-header-pills"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-observation-no-overflow"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-ai-stop-button"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-ai-copy-button"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:action-steps-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:ai-quota-grant-bypass"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-coach-observation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-new-obs-q1-fallback"

[[workflows.workflow]]
name = "test:admin-schools-validation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test:admin-schools-validation"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dashboard-header-pills"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-dashboard && CHROMIUM_PATH=$(which chromium) pnpm test:e2e e2e/app-header-pills.spec.ts"

[[workflows.workflow]]
name = "mobile-observation-no-overflow"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-mobile && PW_BASE_URL=http://127.0.0.1:25869/catalyst-mobile/ CHROMIUM_PATH=$(which chromium) pnpm playwright test --config playwright.config.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dashboard-ai-stop-button"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-dashboard && CHROMIUM_PATH=$(which chromium) pnpm test:e2e e2e/ai-chat-stop-button.spec.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dashboard-ai-copy-button"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-dashboard && CHROMIUM_PATH=$(which chromium) pnpm test:e2e e2e/ai-chat-copy-button.spec.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test:action-steps-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm test:action-steps-e2e"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test:ai-quota-grant-bypass"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run test:ai-quota-grant-bypass"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dashboard-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/catalyst-dashboard run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "mobile-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/catalyst-mobile run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "mobile-coach-observation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-mobile && pnpm vitest run src/test/coach-observation-flow.test.tsx"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "dashboard-new-obs-q1-fallback"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/catalyst-dashboard && CHROMIUM_PATH=$(which chromium) pnpm test:e2e e2e/new-obs-q1-fallback.spec.ts"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
GOOGLE_CALLBACK_URL = "https://catalyst.uncommonschools.org/api/auth/google/callback"
