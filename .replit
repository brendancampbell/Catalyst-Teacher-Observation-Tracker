modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:admin-schools-validation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-header-pills"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-observation-no-overflow"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-ai-stop-button"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-ai-copy-button"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:action-steps-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:ai-quota-grant-bypass"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-coach-observation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-new-obs-q1-fallback"

[[workflows.workflow.tasks]]
