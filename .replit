[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 35000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
GOOGLE_CALLBACK_URL = "https://catalyst.uncommonschools.org/api/auth/google/callback"
