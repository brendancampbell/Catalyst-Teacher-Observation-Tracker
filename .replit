args = "dashboard-instant-analysis-persistence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-instant-analysis-error"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:bulk-upsert-existing-users"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mobile-textarea-autoresize"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "patch-people-school-change-lockout"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-ai-quota-warning"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dashboard-localstorage-cleanup"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:session-expiry"

[[workflows.workflow.tasks]]
